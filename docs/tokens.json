{
  "$description": "Design tokens for the To-Do List Application — 'Fresh Calm' direction (teal + amber). W3C DTCG format. Light values are the default; dark theme values live under the `colorDark` group. Interactive colors are chosen to meet WCAG 2.2 AA contrast (see design.md §5).",
  "color": {
    "$type": "color",
    "background": { "$value": "#F8FAFC", "$description": "App canvas background (light)" },
    "surface": { "$value": "#FFFFFF", "$description": "Cards, panels, sidebar, task rows" },
    "surfaceSunken": { "$value": "#F1F5F9", "$description": "Inset/well backgrounds, hovered rows" },
    "overlay": { "$value": "rgba(15,23,42,0.45)", "$description": "Modal/scrim backdrop" },
    "border": { "$value": "#E2E8F0", "$description": "Default hairline borders, dividers" },
    "borderStrong": { "$value": "#CBD5E1", "$description": "Emphasis borders, input outlines" },
    "text": { "$value": "#0F172A", "$description": "Primary text, headings (17:1 on surface)" },
    "textMuted": { "$value": "#64748B", "$description": "Secondary text, metadata (4.6:1 on bg — AA)" },
    "textSubtle": { "$value": "#94A3B8", "$description": "Non-essential/large text only (<AA for body)" },
    "onPrimary": { "$value": "#FFFFFF", "$description": "Text/icon on primary fill" },
    "primary": { "$value": "#0F766E", "$description": "Primary action/link color (4.5:1 on white — AA)" },
    "primaryHover": { "$value": "#115E59", "$description": "Primary hover" },
    "primaryActive": { "$value": "#134E4A", "$description": "Primary pressed" },
    "primaryBright": { "$value": "#14B8A6", "$description": "Brand hue — non-text accents, selection, checkbox fills" },
    "primarySubtle": { "$value": "#CCFBF1", "$description": "Tinted background: selected nav, teal badges (use with #115E59 text)" },
    "focusRing": { "$value": "#14B8A6", "$description": "Focus ring color" },
    "accent": { "$value": "#F59E0B", "$description": "Amber accent — non-text: medium-priority dot, highlights" },
    "accentText": { "$value": "#B45309", "$description": "Accent as text (4.8:1 on white — AA)" },
    "accentSubtle": { "$value": "#FEF3C7", "$description": "Amber tint background" },
    "success": { "$value": "#059669", "$description": "Complete/success fill, checkmark (3.4:1 graphical)" },
    "successText": { "$value": "#047857", "$description": "Success text (AA)" },
    "successSubtle": { "$value": "#D1FAE5", "$description": "Success tint background" },
    "warning": { "$value": "#D97706", "$description": "Warning fill/icon" },
    "warningText": { "$value": "#B45309", "$description": "Warning text (AA)" },
    "warningSubtle": { "$value": "#FEF3C7", "$description": "Warning tint background" },
    "danger": { "$value": "#DC2626", "$description": "Destructive action/text (4.5:1 on white — AA)" },
    "dangerHover": { "$value": "#B91C1C", "$description": "Danger hover" },
    "dangerSubtle": { "$value": "#FEE2E2", "$description": "Danger tint background" },
    "info": { "$value": "#2563EB", "$description": "Informational fill/text" },
    "infoSubtle": { "$value": "#DBEAFE", "$description": "Info tint background" }
  },
  "priority": {
    "$type": "color",
    "high": { "$value": "#DC2626", "$description": "High priority indicator" },
    "medium": { "$value": "#D97706", "$description": "Medium priority indicator" },
    "low": { "$value": "#2563EB", "$description": "Low priority indicator" },
    "none": { "$value": "#94A3B8", "$description": "No priority (neutral)" }
  },
  "colorDark": {
    "$type": "color",
    "$description": "Dark theme re-valuation of the same roles (applied under [data-theme=dark] / .dark)",
    "background": { "$value": "#0B1220" },
    "surface": { "$value": "#131C2E" },
    "surfaceSunken": { "$value": "#0E1626" },
    "overlay": { "$value": "rgba(0,0,0,0.6)" },
    "border": { "$value": "#1E293B" },
    "borderStrong": { "$value": "#334155" },
    "text": { "$value": "#E8EEF6" },
    "textMuted": { "$value": "#94A3B8" },
    "textSubtle": { "$value": "#64748B" },
    "onPrimary": { "$value": "#04211D", "$description": "Dark text on bright-teal fill" },
    "primary": { "$value": "#2DD4BF", "$description": "Primary action/link on dark (9:1 on bg)" },
    "primaryHover": { "$value": "#5EEAD4" },
    "primaryActive": { "$value": "#99F6E4" },
    "primaryBright": { "$value": "#2DD4BF" },
    "primarySubtle": { "$value": "rgba(45,212,191,0.15)" },
    "focusRing": { "$value": "#2DD4BF" },
    "accent": { "$value": "#FBBF24" },
    "accentText": { "$value": "#FCD34D" },
    "accentSubtle": { "$value": "rgba(251,191,36,0.15)" },
    "success": { "$value": "#34D399" },
    "successText": { "$value": "#6EE7B7" },
    "successSubtle": { "$value": "rgba(16,185,129,0.15)" },
    "warning": { "$value": "#FBBF24" },
    "warningText": { "$value": "#FCD34D" },
    "warningSubtle": { "$value": "rgba(251,191,36,0.15)" },
    "danger": { "$value": "#F87171" },
    "dangerHover": { "$value": "#FCA5A5" },
    "dangerSubtle": { "$value": "rgba(239,68,68,0.15)" },
    "info": { "$value": "#60A5FA" },
    "infoSubtle": { "$value": "rgba(37,99,235,0.18)" }
  },
  "priorityDark": {
    "$type": "color",
    "high": { "$value": "#F87171" },
    "medium": { "$value": "#FBBF24" },
    "low": { "$value": "#60A5FA" },
    "none": { "$value": "#64748B" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"] },
      "mono": { "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "caption": { "$value": "12px" },
      "small": { "$value": "13px" },
      "body": { "$value": "15px" },
      "bodyLg": { "$value": "17px" },
      "h3": { "$value": "20px" },
      "h2": { "$value": "24px" },
      "h1": { "$value": "30px" },
      "display": { "$value": "36px" }
    },
    "lineHeight": {
      "$type": "dimension",
      "caption": { "$value": "16px" },
      "small": { "$value": "18px" },
      "body": { "$value": "22px" },
      "bodyLg": { "$value": "26px" },
      "h3": { "$value": "28px" },
      "h2": { "$value": "32px" },
      "h1": { "$value": "38px" },
      "display": { "$value": "44px" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "0_5": { "$value": "2px" },
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "20px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "8px", "$description": "Default: buttons, inputs, chips" },
    "lg": { "$value": "12px", "$description": "Cards, panels, dialogs" },
    "xl": { "$value": "16px" },
    "full": { "$value": "9999px", "$description": "Pills, avatars, checkboxes, dots" }
  },
  "borderWidth": {
    "$type": "dimension",
    "hairline": { "$value": "1px" },
    "thick": { "$value": "2px", "$description": "Focus rings, selected states" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": { "color": "rgba(15,23,42,0.06)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" } },
    "md": { "$value": { "color": "rgba(15,23,42,0.08)", "offsetX": "0px", "offsetY": "2px", "blur": "8px", "spread": "0px" } },
    "lg": { "$value": { "color": "rgba(15,23,42,0.12)", "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px" } }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "120ms" },
      "base": { "$value": "200ms" },
      "slow": { "$value": "320ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.2, 0, 0, 1] },
      "emphasized": { "$value": [0.3, 0, 0, 1] }
    }
  },
  "size": {
    "$type": "dimension",
    "touchTarget": { "$value": "44px", "$description": "Minimum interactive target (touch)" },
    "controlSm": { "$value": "32px", "$description": "Compact control height (dense desktop)" },
    "controlMd": { "$value": "40px", "$description": "Default control height" },
    "controlLg": { "$value": "48px", "$description": "Prominent buttons / touch" },
    "sidebarWidth": { "$value": "280px" },
    "detailPanelWidth": { "$value": "420px" },
    "contentMax": { "$value": "760px", "$description": "Max width of a task list column" }
  }
}
