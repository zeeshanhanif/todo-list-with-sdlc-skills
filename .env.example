# Copy to .env for local development. NEVER commit a real .env (NFR-MAINT-003).
# In cloud environments these come from Secret Manager (architecture §7), not files.

# Postgres (matches docker-compose.yml). Used by the API, the worker, and migrations.
DATABASE_URL=postgres://todo:todo@localhost:5432/todo

# API service
PORT=3001

# Web -> API base URL (server-side fetch in the Next.js shell)
API_URL=http://localhost:3001

