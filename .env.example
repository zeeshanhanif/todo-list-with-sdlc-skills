# Copy to .env for local development. NEVER commit a real .env (NFR-MAINT-003).
# In cloud environments these are Cloud Run environment variables set at deploy time, not files.

# Postgres (matches docker-compose.yml). Used by the API, the worker, and migrations.
DATABASE_URL=postgres://todo:todo@localhost:5432/todo

# API service
PORT=3001

# Web -> API base URL (server-side fetch in the Next.js shell)
API_URL=http://localhost:3001

# Email delivery worker (FEAT-007). Default provider "log" just logs the message
# (no external account needed). Set EMAIL_PROVIDER=smtp + SMTP_URL to really send.
EMAIL_PROVIDER=log
# SMTP_URL=smtps://user:pass@smtp.example.com:465   # when EMAIL_PROVIDER=smtp
EMAIL_FROM=To-Do <no-reply@todo.local>
PUBLIC_APP_URL=http://localhost:3000
# EMAIL_MAX_ATTEMPTS=5
# EMAIL_BATCH_SIZE=50
# EMAIL_BACKOFF_BASE_SECONDS=60
# EMAIL_BACKOFF_CAP_SECONDS=3600

# --- Stubbed; real values arrive with their slices ---
# SUPABASE_URL=             # ADR-006 (Realtime) — FEAT-019
# SUPABASE_JWT_SECRET=      # ADR-006 — Realtime-scoped token minting
